) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwj65MHzoZyTAxWiVfIAHeg_D7BIhM3J_MWM1YecAcoBBJaHfjs=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnFTU3BVYXBaVnZEQ1VISnhkVGFmbE5rdXpLZ3xBQ3Jtc0ttYzZHMmZxeEIyaDhVMElvVmRLYlczOFplU3FwdTh6MVBkVGxZR2ZLM3VGZ3Zhamc3ZDhRMFMwTXRBTU5OYk15dkdkY3hvTVROLXFtS0tFS0RlMTVhbktUZ203ZENpank2NXYtX0FpMF9iUkFKNmJJOA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnFTU3BVYXBaVnZEQ1VISnhkVGFmbE5rdXpLZ3xBQ3Jtc0ttYzZHMmZxeEIyaDhVMElvVmRLYlczOFplU3FwdTh6MVBkVGxZR2ZLM3VGZ3Zhamc3ZDhRMFMwTXRBTU5OYk15dkdkY3hvTVROLXFtS0tFS0RlMTVhbktUZ203ZENpank2NXYtX0FpMF9iUkFKNmJJOA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT",