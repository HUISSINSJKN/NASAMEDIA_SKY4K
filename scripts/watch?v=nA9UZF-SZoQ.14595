FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CKsBEM2rARgBIhMIo_TRwbKYlQMV4I3UAh0KUSB1SITNyfzFjNWHnAHKAQQSHGxY","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFVINDRrR1dIei1YaGxpbXdHRjh0amhDLTFBd3xBQ3Jtc0tubVFjanZXYWpGTmpUQnloakgwM1pQbkN5azFRT0Y1YXJpNEw0eVp4X1BORVNLZFk1blFoT3F3eXhXckNVUTRDRDExb1h2cUlXSjhqRjVvTHpScF9naVVhMEtJZ1gwRVktbWlHRW4wbnJVcHNhZUxSaw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFVINDRrR1dIei1YaGxpbXdHRjh0amhDLTFBd3xBQ3Jtc0tubVFjanZXYWpGTmpUQnloakgwM1pQbkN5azFRT0Y1YXJpNEw0eVp4X1BORVNLZFk1blFoT3F3eXhXckNVUTRDRDExb1h2cUlXSjhqRjVvTHpScF9naVVhMEtJZ1gwRVktbWlHRW4wbnJVcHNhZUxSaw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"U