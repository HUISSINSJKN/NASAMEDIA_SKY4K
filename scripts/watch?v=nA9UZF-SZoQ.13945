oder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMI45XBt7aClAMVbS9oCB171hO_SITNyfzFjNWHnAHKAQQG8N1L","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbW5SOFpWVzNPcTE3U1JJMlJyZDlYU1NlS3BPZ3xBQ3Jtc0ttZDB3aVZJRV9SZWlvck1pUmN5azN2V3AtYzJiOENKMmlGbkJETm1iRDd1U0NTRFFwZHgtaUkxRk1ubmRla1RYUHlWZmViODlRdW5jNDA2TjRWbHBvUmFOSGFGZGkxbHgyR1NtZkMyeG93aGpmWlQxRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbW5SOFpWVzNPcTE3U1JJMlJyZDlYU1NlS3BPZ3xBQ3Jtc0ttZDB3aVZJRV9SZWlvck1pUmN5azN2V3AtYzJiOENKMmlGbkJETm1iRDd1U0NTRFFwZHgtaUkxRk1ubmRla1RYUHlWZmViODlRdW5jNDA2TjRWbHBvUmFOSGFGZGkxbHgyR1NtZkMyeG93aGpmWlQxRQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEM