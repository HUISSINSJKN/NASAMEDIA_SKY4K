ket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiQ8rHjw8qUAxVAL1cBHQkpM2hIhM3J_MWM1YecAcoBBPY9wNs=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblRCRmdQRVdaRDI4WXhhWjdCbjdPdTZFR0Q0d3xBQ3Jtc0ttSGgzaFZneW9IQXVadXFTX1VPX2ktWWhndEd1Rlp2YUlBOTNGZlZOUS1Tak03bjdZeE00X1MtdE1TQW9fcVRkLVJ4UktiUGRzb09YYXg3Rlo3cDBJb19JMTNsVnAyZlNNZ0t3TnFRZmllV19Ibm4tVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqblRCRmdQRVdaRDI4WXhhWjdCbjdPdTZFR0Q0d3xBQ3Jtc0ttSGgzaFZneW9IQXVadXFTX1VPX2ktWWhndEd1Rlp2YUlBOTNGZlZOUS1Tak03bjdZeE00X1MtdE1TQW9fcVRkLVJ4UktiUGRzb09YYXg3Rlo3cDBJb19JMTNsVnAyZlNNZ0t3TnFRZmllV19Ibm4tVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyN