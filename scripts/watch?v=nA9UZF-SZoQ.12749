ceiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPMBEM2rARgBIhMIivvakJLlkgMVwIe6AB2aFA37SITNyfzFjNWHnAHKAQRrojRF","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGVXZjNNMVVWRjRjblFUV1dKTE5YQ1ZYdVUzQXxBQ3Jtc0tsTFYzY2o2SE9fdjA4VVZQRWNIMTE3cUgyakZxWHJrVGtqSlFCQnh0Z0F3WVZTMm01dTlpNFVFTlJQT2VqN2VGa0lKZl9EaU55TjhrVXU3Nks4TlVMSUNIc0RYVVJhQkI0U3FOcWhaeFAxZHlWZGFUSQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGVXZjNNMVVWRjRjblFUV1dKTE5YQ1ZYdVUzQXxBQ3Jtc0tsTFYzY2o2SE9fdjA4VVZQRWNIMTE3cUgyakZxWHJrVGtqSlFCQnh0Z0F3WVZTMm01dTlpNFVFTlJQT2VqN2VGa0lKZl9EaU55TjhrVXU3Nks4TlVMSUNIc0RYVVJhQkI0U3FOcWhaeFAxZHlWZGFUSQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTE