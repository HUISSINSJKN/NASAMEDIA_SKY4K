 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwjz-8TB6sKVAxVYXcIBHQ2yH_RIhM3J_MWM1YecAcoBBH0jwZU=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnJuS2xvb2J0VFRzbFE0YW5pZ1NNYmg0TXMxZ3xBQ3Jtc0tsRjlzby1yVGxhY2ZwenJOZVhRa0lLX2J2NWlKSTZaSHZnRzQ3ZGFlR1JRbmw1Wl9Yc21PeHdUWVJON2JFeE9kUHVnaVdRYW5hZTF4dVlyaDNwTlZTSlN1ZHNQTTZFaXJNX3hHVXdpYVJ0c3AwZEtGQQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnJuS2xvb2J0VFRzbFE0YW5pZ1NNYmg0TXMxZ3xBQ3Jtc0tsRjlzby1yVGxhY2ZwenJOZVhRa0lLX2J2NWlKSTZaSHZnRzQ3ZGFlR1JRbmw1Wl9Yc21PeHdUWVJON2JFeE9kUHVnaVdRYW5hZTF4dVlyaDNwTlZTSlN1ZHNQTTZFaXJNX3hHVXdpYVJ0c3AwZEtGQQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"ke