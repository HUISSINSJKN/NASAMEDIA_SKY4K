ellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMIoeXZzr7lkwMVBSlXAR08xAGCSITNyfzFjNWHnAHKAQTXQaWK","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbXd3el9yZ2c1Z0p0aUJuRHVONVlnNm9lSXZXd3xBQ3Jtc0trMWstNXZtaXppREtBLXN3MzIwdUdPSlJOejhrOVFOdFR5ZDNGU2RmOFl4UVJHS2dxcUVGUXFpSnpIQklWMTZyYm1JQ2hCMmY5MGpuMTh3NXlWWmR3U2ppV0NZUVhtdDlkV2hfMkFsMTNjTW03R2o4VQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbXd3el9yZ2c1Z0p0aUJuRHVONVlnNm9lSXZXd3xBQ3Jtc0trMWstNXZtaXppREtBLXN3MzIwdUdPSlJOejhrOVFOdFR5ZDNGU2RmOFl4UVJHS2dxcUVGUXFpSnpIQklWMTZyYm1JQ2hCMmY5MGpuMTh3NXlWWmR3U2ppV0NZUVhtdDlkV2hfMkFsMTNjTW03R2o4VQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":429496