simpleText":"Show less"},"trackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCG","defaultExpanded":false,"descriptionCollapsedLines":3,"showMoreCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCGygEE4eB7Qw==","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCGygEE4eB7Qw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_EXPANDED"}},{"clickTrackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCGygEE4eB7Qw==","scrollToEngagementPanelCommand":{"targetId":"engagement-panel-structured-description"}}]}},"showLessCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCGygEE4eB7Qw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},"attributedDescription":{"content":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We will continue to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMI6P6oleXplQMV6AXbAR35VxCGSITNyfzFjNWHnAHKAQTh4HtD","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUM4Zm9rVDFhR1NXNkU4MWhSN05mT3I0TkxyZHxBR3JiS2FucVJpdzdlMDd3RGozVjg5WTZLdVpxY2Y1UzBmX3Jyb1lVNHRBQXc2SS1pbmlUM2dWQWJXcnJBOEtCcDI0aU5fRDF0YkluRHByb2hYNzctUjF0Q0ZJemhpWVV2ZTIw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUM4Zm9rVDFhR1NXNkU4MWhSN05mT3I0TkxyZHxBR3JiS2FucVJpdzdlMDd3RGozVjg5WTZLdVpxY2Y1UzBmX3Jyb1lVNHRBQXc2SS1pbmlUM2dWQWJXcnJBOEtCcDI0aU5fRDF0YkluRHByb2hYNzctUjF0Q0ZJemhpWVV2ZTIw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value