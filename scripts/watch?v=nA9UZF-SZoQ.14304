mmand":{"clickTrackingParams":"CBgQ8FsiEwi4wdWD38SUAxVpDnsCHWgBFLPKAQSPG1F5","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CBgQ8FsiEwi4wdWD38SUAxVpDnsCHWgBFLPKAQSPG1F5","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},{"clickTrackingParams":"CBgQ8FsiEwi4wdWD38SUAxVpDnsCHWgBFLPKAQSPG1F5","updateToggleButtonStateCommand":{"toggled":false,"buttonId":"TOGGLE_BUTTON_ID_TYPE_STRUCTURED_DESCRIPTION"}}]}}}},"trackingParams":"CBIQ040EGAUiEwi4wdWD38SUAxVpDnsCHWgBFLM="}},"content":{"structuredDescriptionContentRenderer":{"items":[{"videoDescriptionHeaderRenderer":{"title":{"runs":[{"text":"NASA Live: Official Stream of NASA TV's Media Channel"}]},"channel":{"simpleText":"NASA"},"views":{"simpleText":"25,057,318 views"},"publishDate":{"simpleText":"Streamed live on Feb 14, 2019"},"channelNavigationEndpoint":{"clickTrackingParams":"CBIQ040EGAUiEwi4wdWD38SUAxVpDnsCHWgBFLPKAQSPG1F5","commandMetadata":{"webCommandMetadata":{"url":"/@NASA","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCLA_DiR1FfKNvjuUpBHmylQ","canonicalBaseUrl":"/@NASA"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/eIf5fNPcIcj9ig-wZBeq4stFy1lgjWTW1nLT5dYlFkHZprZ03QBiMcbpwNMB6XSBjrSFGtAGQg=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We will continue to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwi4wdWD38SUAxVpDnsCHWgBFLNIhM3J_MWM1YecAcoBBI8bUXk=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFB2TVQtV2lYREpwM1BDbGlCaWZxNlJXcVVnUXxBQ3Jtc0tuY0RHMm1RVVNuQ1pSRnBmZ1BlUDJybEdaSjhRVEVxZl80UG1MdEI3c195NkZYUXJ1aFFHYVRhN1JISWZBUE1VZDdXbHV0b2ptdUVQeWt0eld6U2g3NlRfVW9jeE9XOXdaOVZZdzNhLThhTXltRFZtVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbFB2TVQtV2lYREpwM1BDbGlCaWZxNlJXcVVnUXxBQ3Jtc0tuY0RHMm1RVVNuQ1pSRnBmZ1BlUDJybEdaSjhRVEVxZl80UG1MdEI3c195NkZYUXJ1aFFHYVRhN1JISWZBUE1VZDdXbHV0b2ptdUVQeWt0eld6U2g3NlRfVW9jeE9XOXdaOVZZdzNhLThhTXltRFZtVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\