lication" itemscope itemtype="http://schema.org/BroadcastEvent"><meta itemprop="isLiveBroadcast" content="True"><meta itemprop="startDate" content="2019-02-14T17:23:23+00:00"><meta itemprop="endDate" content="2024-08-30T19:12:50+00:00"></span></div></head><body dir="ltr" no-y-overflow><script nonce="WVjFyOjPYfpjo5tP_t4G9A">var ytInitialPlayerResponse = {"responseContext":{"visitorData":"-TEnByuajfdHjPMbM8iopQvq3ADuGo4nqtSBGJweOCG9CW197seDX4_ADh8cKKpN4LDTySAFUYco5V0qYiYi4706C6dqpDxFkcbdpJpahd5fpEAn1MsnMesUEJbKQG2ttByZfLBEVbNkbdEsSabiqxsEiKDTRoY75Dkx1eO50L-LWc0TAZgCgiL0hdW4wjv2tUPZsEdHekDzhjgrEmcd2_hhcUlQN_r0__kbTmVRHuMqYX2gZmNifOdK5iCwbCK0XE4dvXuHSgIp0ICZS90O4ln29fEVi__B998ah0RdofThy4HD-UJ8Gzp3J0GHzL7KzUDnsKsOPD46AaTg3VcfQKgX4gwKnurf_T_DPWzeSjG8gylTd5rjZaUau-57fo_xIICVFPI70PfLPRw0188DBIO7PJG4OG9PMQIR0k4_DrThO8bPOxMzOfRMc%3D","serviceTrackingParams":[{"service":"GFEEDBACK","params":[{"key":"is_alc_surface","value":"false"},{"key":"is_viewed_live","value":"True"},{"key":"ipcc","value":"0"},{"key":"logged_in","value":"0"},{"key":"visitor_data","value":"%3D%3D"}]},{"service":"CSI","params":[{"key":"c","value":"WEB"},{"key":"cver","value":"2.20260302.01.00"},{"key":"yt_li","value":"0"},{"key":"GetPlayer_rid","value":"0x2238cc055b7ec3a2"}]},{"service":"GUIDED_HELP","params":[{"key":"logged_in","value":"0"}]},{"service":"ECATCHER","params":[{"key":"client.version","value":"2.20260302"},{"key":"client.name","value":"WEB"}]}],"maxAgeSeconds":0,"mainAppWebResponseContext":{"loggedOut":true,"trackingParam":"kx_fmPxhoPZR3NI-c2zRoqFdTMehgwe17SglTni9QU3VDZzRgkuMsNLBwOcCE59TDtslLKPQ-SS"},"webResponseContextExtensionData":{"webResponseContextPreloadData":{"preloadMessageNames":["playerErrorMessageRenderer","miniplayerRenderer","playerMicroformatRenderer","mealbarPromoRenderer","buttonRenderer"]},"hasDecorated":true}},"playabilityStatus":{"status":"UNPLAYABLE","reason":"This live stream recording is not available.","errorScreen":{"playerErrorMessageRenderer":{"reason":{"simpleText":"This live stream recording is not available."},"thumbnail":{"thumbnails":[{"url":"//s.ytimg.com/yts/img/meh7-vflGevej7.png","width":140,"height":100}]},"icon":{"iconType":"ERROR_OUTLINE"}}},"playableInEmbed":true,"miniplayer":{"miniplayerRenderer":{"playbackMode":"PLAYBACK_MODE_ALLOW"}},"contextParams":"Q0FFU0FnZ0M="},"videoDetails":{"videoId":"nA9UZF-SZoQ","title":"NASA Live: Official Stream of NASA TV's Media Channel","lengthSeconds":"174880167","channelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isOwnerViewing":false,"shortDescription":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","isCrawlable":false,"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/hqdefault.jpg?v=6412251c\u0026sqp=CJSCms0G-oaymwEiCKgBEF5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLBa2O7eS8vn0qvbnCRseYMObOLeig","width":168,"height":94},{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/hqdefault.jpg?v=6412251c\u0026sqp=CJSCms0G-oaymwEiCMQBEG5IWvKriqkDFQgBFQAAAAAYASUAAMhCPQCAokN4AQ==\u0026rs=AOn4CLBiOefYeqUKa-MSnYJhXfPdzcvxGg","width":196,"height":110},{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/hqdefault.jpg?v=6412251c\u0026sqp=CJSCms0G-oaymwEjCPYBEIoBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLAVBTPqjYm3ftUBmUUUU0Bj9uoITg","width":246,"height":138},{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/hqdefault.jpg?v=6412251c\u0026sqp=CJSCms0G-oaymwEjCNACELwBSFryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=\u0026rs=AOn4CLAa761kOf-dqZZ2-12O4fVUKCWCJw","width":336,"height":188},{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/maxresdefault.jpg?v=6412251c","width":1920,"height":1080}]},"allowRatings":true,"viewCount":"25057318","author":"NASA","isLowLatencyLiveStream":false,"isPrivate":false,"isUnpluggedCorpus":false,"latencyClass":"MDE_STREAM_OPTIMIZATIONS_RENDERER_LATENCY_NORMAL","isLiveContent":true,"isPostLiveDvr":true},"microformat":{"playerMicroformatRenderer":{"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/nA9UZF-SZoQ/maxresdefault.jpg?v=6412251c","width":1280,"height":720}]},"embed":{"iframeUrl":"https://www.youtube.com/embed/nA9UZF-SZoQ","width":480,"height":360},"title":{"simpleText":"NASA Live: Official Stream of NASA TV's Media Channel"},"description":{"simpleText":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We *will continue* to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception."},"lengthSeconds":"174880167","ownerProfileUrl":"http://www.youtube.com/@NASA","externalChannelId":"UCLA_DiR1FfKNvjuUpBHmylQ","isFamilySafe":true,"availableCountries":["AD","AE","AF","AG","AI","AL","AM","AO","AQ","AR","AS","AT","AU","AW","AX","AZ","BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BQ","BR","BS","BT","BV","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN","CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC","EE","EG","EH","ER","ES","ET","FI","FJ","FK","FM","FO","FR","GA","GB","GD","GE","GF","GG","GH","GI","GL","GM","GN","GP","GQ","GR","GS","GT","GU","GW","GY","HK","HM","HN","HR","HT","HU","ID","IE","IL","IM","IN","IO","IQ","IR","IS","IT","JE","JM","JO","JP","KE","KG","KH","KI","KM","KN","KP","KR","KW","KY","KZ","LA","LB","LC","LI","LK","LR","LS","LT","LU","LV","LY","MA","MC","MD","ME","MF","MG","MH","MK","ML","MM","MN","MO","MP","MQ","MR","MS","MT","MU","MV","MW","MX","MY","MZ","NA","NC","NE","NF","N