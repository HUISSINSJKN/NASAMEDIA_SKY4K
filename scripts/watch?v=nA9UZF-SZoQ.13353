roadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBMQ040EGAUiEwjT4d-qtK-TAxU_-pQJHco0MqhIhM3J_MWM1YecAcoBBHC2q_Y=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbkxfc1dZVEk5M3JIcFJuSUNhV2ZXeUpOZzJPZ3xBQ3Jtc0tsZE9xajRpMmduVnFRQ2QtanE4bUZheGZHaDRrYjBOc0pRN2VBeGhHNjMzRXpPMEZLc3ZmYWtCa0Noa2ZCRHNBMFU3RFlCc3RpY0c4NWVnbUx3Z0hGODFwaURia2NXS2pZSmVsYjcxUHpZWnBFeHoxQQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbkxfc1dZVEk5M3JIcFJuSUNhV2ZXeUpOZzJPZ3xBQ3Jtc0tsZE9xajRpMmduVnFRQ2QtanE4bUZheGZHaDRrYjBOc0pRN2VBeGhHNjMzRXpPMEZLc3ZmYWtCa0Noa2ZCRHNBMFU3RFlCc3RpY0c4NWVnbUx3Z0hGODFwaURia2NXS2pZSmVsYjcxUHpZWnBFeHoxQQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DA