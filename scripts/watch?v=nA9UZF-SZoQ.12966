eded for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMIkoCkyNz_kgMVgKsrBh1chgdcSITNyfzFjNWHnAHKAQQheDpO","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnk2WjlydlpjOGhTWklsLWJqRWVtTU82dXlOZ3xBQ3Jtc0ttUUp2TFUwcWJuNGJuODMyZl9BaFJtVkFqZV9uTGRYWnVZZDJMbkVvTFlrbmI3amdyZGdxVGdIcEpqLWpYTEFMeVdiVmdfcHZNS2NvVDJ1aU5OX3k1bVVQcHhvQlJDTGFmTUNNRHdIaml0aWVhZkNoVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnk2WjlydlpjOGhTWklsLWJqRWVtTU82dXlOZ3xBQ3Jtc0ttUUp2TFUwcWJuNGJuODMyZl9BaFJtVkFqZV9uTGRYWnVZZDJMbkVvTFlrbmI3amdyZGdxVGdIcEpqLWpYTEFMeVdiVmdfcHZNS2NvVDJ1aU5OX3k1bVVQcHhvQlJDTGFmTUNNRHdIaml0aWVhZkNoVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT","value"