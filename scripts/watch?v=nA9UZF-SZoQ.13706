) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPkBEM2rARgBIhMI78u4o-rekwMV0gVoCB2MygGJSITNyfzFjNWHnAHKAQTsWwp-","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbWY4dE9WUHZPaTVSUV9sRFJnMXZIWWZmd3ltZ3xBQ3Jtc0tsWjNqcDkyMzNROHg1LWxKWVFlZ0gxYkNyUUc0eDlGWVhnNDNQUi1ZVUVhOEJCWHRFc3NLVTZVX0FsS2lGR0xJMVp0YkdDS192M0JYNHl4X2dxXzVPLVRNeHR3dF9MMkFrZ1ZNbjJjQV9ZeG5XZllsUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbWY4dE9WUHZPaTVSUV9sRFJnMXZIWWZmd3ltZ3xBQ3Jtc0tsWjNqcDkyMzNROHg1LWxKWVFlZ0gxYkNyUUc0eDlGWVhnNDNQUi1ZVUVhOEJCWHRFc3NLVTZVX0FsS2lGR0xJMVp0YkdDS192M0JYNHl4X2dxXzVPLVRNeHR3dF9MMkFrZ1ZNbjJjQV9ZeG5XZllsUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282