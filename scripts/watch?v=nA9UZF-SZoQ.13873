Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPcBEM2rARgBIhMInPbg09v3kwMVpRaGAB16OQYESITNyfzFjNWHnAHKAQSFqLhX","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa3FXMWdKbjZaNm52T3ptYWR5bGZSaW41aFJod3xBQ3Jtc0tsZWJpU3k3Sm1xRk15cjVpLXcxV0hobk1CNm1jcU1faEVkREhsR1RpX3Y3bjk1S0g2RFdUU2dxbTlSVGoyV1VnbTYxdGl5R200d2xGMi1Ea3VxRHFjZU0zRzFtcjdMTjh4czRpeWxSa09NQ1FhTGJwYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa3FXMWdKbjZaNm52T3ptYWR5bGZSaW41aFJod3xBQ3Jtc0tsZWJpU3k3Sm1xRk15cjVpLXcxV0hobk1CNm1jcU1faEVkREhsR1RpX3Y3bjk1S0g2RFdUU2dxbTlSVGoyV1VnbTYxdGl5R200d2xGMi1Ea3VxRHFjZU0zRzFtcjdMTjh4czRpeWxSa09NQ1FhTGJwYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorM