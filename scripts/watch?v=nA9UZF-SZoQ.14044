oder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPsBEM2rARgBIhMI9qew6cuSlAMV4F8_AR1K7C72SITNyfzFjNWHnAHKAQSiQuIu","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnBPYXl3dUd0RUJSd3pGdWlsNmR3Z0VfZnFXZ3xBQ3Jtc0tsMHljV0cwNVd3aWYwcDlBeEVDbVM4N0hzV252d25KTXlWQlEwbXFpQ1pXbTJkNTVpLWlQNUhnSERBRmltMjZXeHYzX2swUkdwVXNnMW1yUFZrSHZwSk5wVE4tMThoRHZacHdVY09taE9WeEdrN0JmYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbnBPYXl3dUd0RUJSd3pGdWlsNmR3Z0VfZnFXZ3xBQ3Jtc0tsMHljV0cwNVd3aWYwcDlBeEVDbVM4N0hzV252d25KTXlWQlEwbXFpQ1pXbTJkNTVpLWlQNUhnSERBRmltMjZXeHYzX2swUkdwVXNnMW1yUFZrSHZwSk5wVE4tMThoRHZacHdVY09taE9WeEdrN0JmYw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEM