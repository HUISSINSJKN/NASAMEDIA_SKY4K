C. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwit3aeB5NyVAxXoP1cBHVX6NUFIhM3J_MWM1YecAcoBBGFYpbM=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGF5TDdMSVNNbkVtMl9COGx2WkcxTHhRMDJCUXxBQ3Jtc0ttcDRkVUdGZ3NhVmFtZmNFWlBGN3ZzaHpwSWlVNElJSlp1cU9xQTRKSmhnc1liQmFyM0F5YTRGaVZDeDVkQ0RudktvenBnSFA1dXhSNlNlVmhQY3k0Mkx1ckJXWVVvZWllZmxoZk9sRXpZZE9rZWRPUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGF5TDdMSVNNbkVtMl9COGx2WkcxTHhRMDJCUXxBQ3Jtc0ttcDRkVUdGZ3NhVmFtZmNFWlBGN3ZzaHpwSWlVNElJSlp1cU9xQTRKSmhnc1liQmFyM0F5YTRGaVZDeDVkQ0RudktvenBnSFA1dXhSNlNlVmhQY3k0Mkx1ckJXWVVvZWllZmxoZk9sRXpZZE9rZWRPUQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USE