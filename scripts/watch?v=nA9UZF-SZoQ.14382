. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwib7Yna3deUAxWNCW0HHXiMM89IhM3J_MWM1YecAcoBBM4EwIE=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbmJtUlVyS2dSRlZRZ0FSRkJZOUJLY0lvYTFCQXxBQ3Jtc0ttUndOWHYzSllFNWpXNzV3bzNzY1NHSW1weEF0OENtb3NGM2ZNZ2lVcnJfNnRTdUJQWmxnU0Z3cmRRRmNDVEM1dGlGMC1xRjdldDhBQmFSTHZXR0duSlRQd25XVEVZUFZveGh2QmhLZW1iNFZiMmthMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbmJtUlVyS2dSRlZRZ0FSRkJZOUJLY0lvYTFCQXxBQ3Jtc0ttUndOWHYzSllFNWpXNzV3bzNzY1NHSW1weEF0OENtb3NGM2ZNZ2lVcnJfNnRTdUJQWmxnU0Z3cmRRRmNDVEM1dGlGMC1xRjdldDhBQmFSTHZXR0duSlRQd25XVEVZUFZveGh2QmhLZW1iNFZiMmthMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER