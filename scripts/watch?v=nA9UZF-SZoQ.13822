zontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwja66LSnPCTAxXIGmgIHRkwOSZIhM3J_MWM1YecAcoBBDDQGMc=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbThKTzJUZEllV1R4bEZtYUVFMWVhWGhoZUtpd3xBQ3Jtc0tsd2l5OWN6ejUxQ3JnVDl6UWo3Y1B1dUhEa3B6ZlBQM3hLVDkxSW9XNkxCQUtjcXp0ZGxmRVExbFdubERQR3ExbnFTTXVBXzZrUmp6MHpqeGdoa3NoOG1mWVNHX0NURE1QWVBoWkI1ZGV0RUFobGhObw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbThKTzJUZEllV1R4bEZtYUVFMWVhWGhoZUtpd3xBQ3Jtc0tsd2l5OWN6ejUxQ3JnVDl6UWo3Y1B1dUhEa3B6ZlBQM3hLVDkxSW9XNkxCQUtjcXp0ZGxmRVExbFdubERQR3ExbnFTTXVBXzZrUmp6MHpqeGdoa3NoOG1mWVNHX0NURE1QWVBoWkI1ZGV0RUFobGhObw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex