on.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPgBEM2rARgBIhMIv_Hbkcb5kwMVlL0rBh2TYAY6SITNyfzFjNWHnAHKAQRxVyY3","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjVQaHlDTmM3bGFfU0R0VHFPWDIxQlZGOXVCQXxBQ3Jtc0ttNWFCSnIzck5jcTlfUklPUVRpZGlGS3ppZ0pRUHIweWdLLWRKdnRjbEFCcFhtQU8tNkZITHV0VEEtUWdyYVQxRVp1dkt0MHF2WGMtVjJ6dWNBS1hEVWw3VjNtbE9CUHpGczRqMWs5N1haYmFMT0FXNA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjVQaHlDTmM3bGFfU0R0VHFPWDIxQlZGOXVCQXxBQ3Jtc0ttNWFCSnIzck5jcTlfUklPUVRpZGlGS3ppZ0pRUHIweWdLLWRKdnRjbEFCcFhtQU8tNkZITHV0VEEtUWdyYVQxRVp1dkt0MHF2WGMtVjJ6dWNBS1hEVWw3VjNtbE9CUHpGczRqMWs5N1haYmFMT0FXNA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278607828}]}},