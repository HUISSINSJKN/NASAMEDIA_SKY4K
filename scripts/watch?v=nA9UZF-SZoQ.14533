ymbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CK0BEM2rARgBIhMI47Ls_6eElQMVWB9oCB35ggQ9SITNyfzFjNWHnAHKAQS7I8ro","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbEtoRkhWMk5GQkJRMzNDWDVyRkNuYWVJSy1sUXxBQ3Jtc0trV1ZlbTNxSkFNc0xuUUlYSHVsQ3BweFNFTTJ2aDNkMzNRWnFWdjFHUjVnLU9SSDJ5R1ltVWNOME5TUjZnbzBhR0NsT1RmaTBZbmgxa0o2M3RjR3pXVW90cXJpb1I2MHY5LVdERklua1g4bHdZRGNwZw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbEtoRkhWMk5GQkJRMzNDWDVyRkNuYWVJSy1sUXxBQ3Jtc0trV1ZlbTNxSkFNc0xuUUlYSHVsQ3BweFNFTTJ2aDNkMzNRWnFWdjFHUjVnLU9SSDJ5R1ltVWNOME5TUjZnbzBhR0NsT1RmaTBZbmgxa0o2M3RjR3pXVW90cXJpb1I2MHY5LVdERklua1g4bHdZRGNwZw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorM