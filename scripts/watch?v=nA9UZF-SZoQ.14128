ps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwiunK2LzKGUAxX5SfIAHeA6BU1IhM3J_MWM1YecAcoBBJ608bg=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbldjTHFobHprTnBESTFqemlRMDlNOVJadU5rQXxBQ3Jtc0trelRnTnlwazR4cHUzSVBOZ3R1WDRZbTE2NHFxSzBnUmFOUnhyQTZ5QklSY0trdFhVMzI4RV9WTHVJMjNEdXZjaTFoUk02U0hUaXhhai0zdUk2V3dlT01CcGVweThCd0NHTE8xenJfU0dCaXk4M0VTVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbldjTHFobHprTnBESTFqemlRMDlNOVJadU5rQXxBQ3Jtc0trelRnTnlwazR4cHUzSVBOZ3R1WDRZbTE2NHFxSzBnUmFOUnhyQTZ5QklSY0trdFhVMzI4RV9WTHVJMjNEdXZjaTFoUk02U0hUaXhhai0zdUk2V3dlT01CcGVweThCd0NHTE8xenJfU0dCaXk4M0VTVQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunC