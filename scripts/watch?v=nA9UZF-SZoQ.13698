 States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwjqlIeZzd2TAxXwoCsGHaZZNqxIhM3J_MWM1YecAcoBBDs-i6w=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjBKcFIwQzVFejljdnczQS1RdHdaaHNVdFBqUXxBQ3Jtc0trVC12MGdkNm1GQ211SGVLV0tQcm5JVWZIclNDZWJJR3FWV2Q5N2ZaYXBmSFo0T1pYdVJjdG4zZDZ0TWxJMjJjeEhSelkzWlg2ZnZnTThRMjVMbXlUakV1aVg4QkROckI0MHpnUk4xY1p0ZHBoVl9Eaw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjBKcFIwQzVFejljdnczQS1RdHdaaHNVdFBqUXxBQ3Jtc0trVC12MGdkNm1GQ211SGVLV0tQcm5JVWZIclNDZWJJR3FWV2Q5N2ZaYXBmSFo0T1pYdVJjdG4zZDZ0TWxJMjJjeEhSelkzWlg2ZnZnTThRMjVMbXlUakV1aVg4QkROckI0MHpnUk4xY1p0ZHBoVl9Eaw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":9