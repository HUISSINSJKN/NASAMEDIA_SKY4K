unches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwjh_r77jtyTAxXLIVcBHcR2B19IhM3J_MWM1YecAcoBBHwC_C4=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjJTQk4tQXRCV01RblhPMDRDRjliQ0NJV0dzZ3xBQ3Jtc0trM1RHdG9BV0FNZ3d0eF9YX0NQQ1JtdnktUmhTUXlXTEpVRzNIVUxKSUg0TGVRQ3pwY1l2cG1XRWJZOTlaWkNtbWYtVElqWWdjRXFyZ3puUHhWMnl3ampueTdZdC14Wkw0UkY2eGw5cGZSenBFZ2l4dw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbjJTQk4tQXRCV01RblhPMDRDRjliQ0NJV0dzZ3xBQ3Jtc0trM1RHdG9BV0FNZ3d0eF9YX0NQQ1JtdnktUmhTUXlXTEpVRzNIVUxKSUg0TGVRQ3pwY1l2cG1XRWJZOTlaWkNtbWYtVElqWWdjRXFyZ3puUHhWMnl3ampueTdZdC14Wkw0UkY2eGw5cGZSenBFZ2l4dw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4292932346},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278855734}]}},"fontFamilyName":"