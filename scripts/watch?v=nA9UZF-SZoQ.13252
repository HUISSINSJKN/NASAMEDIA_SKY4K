ception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPgBEM2rARgBIhMIx42nu8OikwMVjQ5oCB22swtWSITNyfzFjNWHnAHKAQRCWRaq","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGpMak1JNXA3YmowWTNyNm9YaVVESHNaQ1U4QXxBQ3Jtc0tseEwyNE92aEZHRm9yR2UyeG1XM3lQbDNwMHdNZGEycWxhczg4d1VxbTk0QnQ1czNFYTlpM0FrSnRoMXQ3MUJrY2E5U0pidXc4REVkREFYQnNCenJ2RTY1WFktc05TSjFONDRVOXFCYnlObFVHUVBURQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbGpMak1JNXA3YmowWTNyNm9YaVVESHNaQ1U4QXxBQ3Jtc0tseEwyNE92aEZHRm9yR2UyeG1XM3lQbDNwMHdNZGEycWxhczg4d1VxbTk0QnQ1czNFYTlpM0FrSnRoMXQ3MUJrY2E5U0pidXc4REVkREFYQnNCenJ2RTY1WFktc05TSjFONDRVOXFCYnlObFVHUVBURQ\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278607828