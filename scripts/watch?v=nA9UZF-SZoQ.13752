 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CPgBEM2rARgBIhMIsarJscrlkwMVidGVAh1Y0QP5SITNyfzFjNWHnAHKAQRdex0Q","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHNRaEcyUjZkNS1BSjI2VERScl9RdEQ3SV9Sd3xBQ3Jtc0ttMkE3QTdhN0FxRDR4M1pHS3pSUmlKSHdRVmw5cUlyb2xaYnNrRnVCak9uNTNVX0dIWTNtR0pRT1ZTbDhINHRBbWhwb1pYbW1TYU5uRzMyeGR5WWhCT0xpSTBhVWo4LUF5d2V2Z3laZjRNeTdSVjNwMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHNRaEcyUjZkNS1BSjI2VERScl9RdEQ3SV9Sd3xBQ3Jtc0ttMkE3QTdhN0FxRDR4M1pHS3pSUmlKSHdRVmw5cUlyb2xaYnNrRnVCak9uNTNVX0dIWTNtR0pRT1ZTbDhINHRBbWhwb1pYbW1TYU5uRzMyeGR5WWhCT0xpSTBhVWo4LUF5d2V2Z3laZjRNeTdSVjNwMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleR