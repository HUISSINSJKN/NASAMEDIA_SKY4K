iews":{"simpleText":"25,057,318 views"},"publishDate":{"simpleText":"Streamed live on Feb 14, 2019"},"channelNavigationEndpoint":{"clickTrackingParams":"CBIQ040EGAUiEwidvIGJ4-qSAxXedT8BHcd9AVbKAQRdV1Dz","commandMetadata":{"webCommandMetadata":{"url":"/@NASA","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UCLA_DiR1FfKNvjuUpBHmylQ","canonicalBaseUrl":"/@NASA"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/eIf5fNPcIcj9ig-wZBeq4stFy1lgjWTW1nLT5dYlFkHZprZ03QBiMcbpwNMB6XSBjrSFGtAGQg=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We will continue to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwidvIGJ4-qSAxXedT8BHcd9AVZIhM3J_MWM1YecAcoBBF1XUPM=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa1NVdkdsSnZUS0R0TGRYUmRJdFdhWlBDdktkQXxBQ3Jtc0tuNGUwdzJKZnBlX2U2c3NlZE44ZGtCRnNsMjdGd0Y5VEZWSFktaWVhTzluOE5zcGk3UDA4V002QmdtQzVFR0dKQ2dmTUtSUmNNcjRfWDE2eldOQ2JhaGU5MjJrTi1KdWp2VGktT3c2bDNlTDhqZ2h5aw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqa1NVdkdsSnZUS0R0TGRYUmRJdFdhWlBDdktkQXxBQ3Jtc0tuNGUwdzJKZnBlX2U2c3NlZE44ZGtCRnNsMjdGd0Y5VEZWSFktaWVhTzluOE5zcGk3UDA4V002QmdtQzVFR0dKQ2dmTUtSUmNNcjRfWDE2eldOQ2JhaGU5MjJrTi1KdWp2VGktT3c2bDNlTDhqZ2h5aw\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WINDOW","nofollow":true}}}}],"styleRuns":[{"startIndex":0,"length":83,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":83,"length":13,"fontName":"Roboto-Medium","weightLabel":"FONT_WEIGHT_BOLD","styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":96,"length":246,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"},{"startIndex":342,"length":22,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4282296063},{"key":"USER_INTERFACE_THEME_LIGHT","value":4278607828}]}},"fontFamilyName":"Roboto"},{"startIndex":364,"length":1057,"styleRunExtensions":{"styleRunColorMapExtension":{"colorMap":[{"key":"USER_INTERFACE_THEME_DARK","value":4294967295},{"key":"USER_INTERFACE_THEME_LIGHT","value":4279440147}]}},"fontFamilyName":"Roboto"}]},"headerRuns":[{"startIndex":0,"length":83,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":83,"length":13,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":96,"length":246,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":342,"length":22,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"},{"startIndex":364,"length":1057,"headerMapping":"ATTRIBUTED_STRING_HEADER_MAPPING_UNSPECIFIED"}],"backgroundColorStyle":"BACKGROUND_COLOR_STYLE_COLOR_SAMPLED","lightThemeColorPalette":{"baseBackground":4293982975,"raisedBackground":4293982975,"additiveBackground":558212041,"textPrimary":4278855734,"textSecondary":4282015342,"invertedBackground":4279856015,"overlayBackground":3423217718},"darkThemeColorPalette":{"baseBackground":4278326300,"raisedBackground":4278855734,"additiveBackground":725984201,"textPrimary":4292932346,"textSecondary":4289515229,"invertedBackground":4286366947,"overlayBackground":3423217718},"colorSampledDescriptionBodyText":{"content":"UPDATE: Our 24/7 NASA TV media channel is being phased out as of Aug. 28, 2024. We will continue to stream live events and share new videos on our YouTube account—please subscribe to our channel to make sure you get the latest updates!\n\nWe'll also continue to stream live views from the International Space Station on this page. Visit NASA+ (https://plus.nasa.gov/) for more live events and original NASA shows.\n\n=========================================\n\nDirect from America's space program to YouTube, watch NASA TV live streaming here to get the latest from our exploration of the universe and learn how we discover our home planet.\n\nNASA TV airs a variety of regularly scheduled, pre-recorded educational and public relations programming 24 hours a day on its various channels. The network also provides an array of live programming, such as 24-hour coverage of missions, events (spacewalks, media interviews, educational broadcasts), press conferences and rocket launches.\n\nIn the United States, NASA Television's Public and Media channels are MPEG-2 digital C-band signals carried by DVB-S2/8PSK modulation on satellite Galaxy 37, transponder 15, at 127 degrees west longitude. Downlink frequency is 4009.00 MHz, horizontal polarization, with a data rate of 36.225 Mbps, symbol rate of 15.000 Msps, and 5/6 FEC. A Digital Video Broadcast (DVB-S2) compliant Integrated Receiver Decoder (IRD) is needed for reception.","commandRuns":[{"startIndex":342,"length":22,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBIQ040EGAUiEwidvIGJ4-qSAxXedT8BHcd9AVZIhM3J_MWM1YecAcoBBF1XUPM=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUZXdWV6RTVNWVhTSGctMzdUcUs3RG9JUl8yUXxBQ3Jtc0tsU2dzNFM2aGk2RFJDU3NVcFJ3VllqX1I3NmY3RmJmVmQybEdWTHloYkxfN3J6dmZYMWREcVlNbHdLN3dZSjdtaUI4TVduUFlnRzA4LVl3anEtSi1XcUZTV21GTlFOTXdwSWJIRU92UE51ZzVuN0RhMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","webPageType":"WEB_PAGE_TYPE_UNKNOWN","rootVe":83769}},"urlEndpoint":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbUZXdWV6RTVNWVhTSGctMzdUcUs3RG9JUl8yUXxBQ3Jtc0tsU2dzNFM2aGk2RFJDU3NVcFJ3VllqX1I3NmY3RmJmVmQybEdWTHloYkxfN3J6dmZYMWREcVlNbHdLN3dZSjdtaUI4TVduUFlnRzA4LVl3anEtSi1XcUZTV21GTlFOTXdwSWJIRU92UE51ZzVuN0RhMA\u0026q=https%3A%2F%2Fplus.nasa.gov%2F\u0026v=nA9UZF-SZoQ","target":"TARGET_NEW_WIND